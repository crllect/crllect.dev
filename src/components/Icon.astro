---
import {
	ArrowRight,
	ArrowUpRight,
	ArrowDown,
	Mail,
	Globe,
	Copy,
	Sun,
	Moon,
	Sparkles,
	ChevronRight,
	Triangle,
} from 'lucide-preact';
import { fetchBrandSvg } from '../lib/svgl';

type IconName =
	| 'github'
	| 'gitlab'
	| 'discord'
	| 'mail'
	| 'globe'
	| 'copy'
	| 'arrow-right'
	| 'arrow-up-right'
	| 'arrow-down'
	| 'sun'
	| 'moon'
	| 'sparkles'
	| 'chevron-right'
	| 'triangle';

interface Props {
	name: IconName;
	class?: string;
	size?: number;
}

const { name, class: className, size = 20 } = Astro.props;

const lucideMap: Partial<Record<IconName, any>> = {
	mail: Mail,
	globe: Globe,
	copy: Copy,
	'arrow-right': ArrowRight,
	'arrow-up-right': ArrowUpRight,
	'arrow-down': ArrowDown,
	sun: Sun,
	moon: Moon,
	sparkles: Sparkles,
	'chevron-right': ChevronRight,
	triangle: Triangle,
};

const svglTitles: Partial<Record<IconName, string>> = {
	github: 'GitHub',
	gitlab: 'GitLab',
	discord: 'Discord',
};

const LucideIcon = lucideMap[name];
const brandTitle = svglTitles[name];
const brandSvg = brandTitle ? await fetchBrandSvg(brandTitle, size, className) : null;
---

{LucideIcon ? (
	<LucideIcon
		size={size}
		strokeWidth={1.75}
		class={className}
		aria-hidden="true"
	/>
) : brandSvg ? (
	<Fragment set:html={brandSvg} />
) : null}
