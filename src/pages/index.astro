---
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.tsx';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Icon from '../components/Icon.astro';
import {
	contactLinks,
	projects,
	skills,
	recognition,
	education
} from '../data/site';

const featured = projects.filter(p => p.featured);
---

<Base>
	<section class="hero container" id="top">
		<Reveal client:load>
			<span class="eyebrow"> Crllect </span>
		</Reveal>

		<Reveal client:load delay={0.08}>
			<h1 class="hero-name">Leonardo Glorioso</h1>
		</Reveal>

		<Reveal client:load delay={0.16}>
			<p class="hero-lead">
				I build the web at <strong>Night Network</strong>; from a
				<a
					class="serif hero-link"
					href="https://daydreamx.pro"
					target="_blank"
					rel="noreferrer">browser inside a browser</a
				> to open-source tools, used by <span class="gradient-text"
					>500k+</span
				> people a day.
			</p>
		</Reveal>

		<Reveal client:load delay={0.24}>
			<p class="hero-sub mono">Cambridge, MA</p>
		</Reveal>

		<Reveal client:load delay={0.32}>
			<div class="hero-actions">
				<a class="btn-primary" href="/projects">
					View projects
					<Icon name="arrow-right" size={17} />
				</a>
				<a class="btn-ghost" href="/contact">Get in touch</a>
			</div>
		</Reveal>

		<a class="scroll-hint" href="#about" aria-label="Scroll to about">
			<span class="mono">scroll</span>
			<Icon name="arrow-down" size={16} />
		</a>
	</section>

	<section class="container section">
		<div class="about-grid">
			<div>
				<Reveal client:visible>
					<SectionHeading title="About" id="about" />
				</Reveal>
				<div class="about-body">
					<Reveal client:visible>
						<p>
							I'm Leo (online, <strong>Crllect</strong>), a
							developer in Cambridge, MA, focused on building
							products people actually use. I'm{' '}
							<strong>
								co-owner and a developer at Night Network</strong
							>, a privacy- and access-focused web organization
							that partners with TitaniumNetwork and serves{' '}
							<strong>hundreds of thousands of users a day</strong
							>
							at peak.
						</p>
					</Reveal>
					<Reveal client:visible delay={0.06}>
						<p>
							Most of my work blends careful frontend craft with
							the backend and infrastructure to run it at scale. I
							care a lot about UI/UX, performance, and shipping
							things that feel finished. My day-to-day stack is{
								' '
							}
							<strong>
								Astro, TypeScript, Tailwind, and Bun</strong
							>, and I lean into React/Preact when a project needs
							it.
						</p>
					</Reveal>
					<Reveal client:visible delay={0.12}>
						<p>
							Outside of Night Network I build open-source tools,
							do some security research with my school district's
							IT team, and have done a couple of hackathons.
						</p>
					</Reveal>
				</div>
			</div>

			<Reveal client:visible delay={0.1}>
				<aside class="glow-card glance">
					<h3 class="glance-head mono">At a glance</h3>
					<dl>
						<div>
							<dt>Based in</dt>
							<dd>Cambridge, MA</dd>
						</div>
						<div>
							<dt>Role</dt>
							<dd>Co-owner, Night Network</dd>
						</div>
						<div>
							<dt>Education</dt>
							<dd>{education.school}<br />{education.detail}</dd>
						</div>
						<div>
							<dt>Daily stack</dt>
							<dd>Astro · TypeScript · Tailwind · Bun</dd>
						</div>
					</dl>
				</aside>
			</Reveal>
		</div>
	</section>

	<section class="container section" id="work">
		<Reveal client:visible>
			<SectionHeading title="Things I've built">
				A few of the products I've shipped — most are live and in daily
				use.
			</SectionHeading>
		</Reveal>

		<div class="project-grid">
			{
				featured.map((p, i) => (
					<Reveal client:visible delay={i * 0.08}>
						<ProjectCard project={p} />
					</Reveal>
				))
			}
		</div>

		<Reveal client:visible>
			<div class="work-more">
				<a class="btn-ghost" href="/projects">
					See all projects
					<Icon name="arrow-right" size={16} />
				</a>
			</div>
		</Reveal>
	</section>

	<section class="container section">
		<Reveal client:visible>
			<SectionHeading title="What I work with" />
		</Reveal>
		<div class="skills-grid">
			{
				skills.map((g, i) => (
					<Reveal client:visible delay={i * 0.06}>
						<div class="glow-card skill-card">
							<h3 class="skill-head mono">{g.title}</h3>
							<ul>
								{g.items.map(it =>
									it.href ? (
										<li>
											<a
												class="skill-link"
												href={it.href}
												target="_blank"
												rel="noreferrer"
											>
												{it.label}
											</a>
										</li>
									) : (
										<li>{it.label}</li>
									)
								)}
							</ul>
						</div>
					</Reveal>
				))
			}
		</div>
	</section>

	<section class="container section">
		<Reveal client:visible>
			<SectionHeading title="Recognition & activities" />
		</Reveal>
		<ul class="rec-list">
			{
				recognition.map((r, i) => (
					<Reveal client:visible delay={i * 0.05}>
						<li class="rec-item">
							<div class="rec-main">
								<span class="rec-title">{r.title}</span>
								<span class="rec-org">{r.org}</span>
							</div>
							{r.note && <p class="rec-note">{r.note}</p>}
							<span class="rec-period mono">{r.period}</span>
						</li>
					</Reveal>
				))
			}
		</ul>
	</section>

	<section class="container section">
		<Reveal client:visible>
			<div class="glow-card contact-cta">
				<h2 class="cta-title">
					Let's build something <span class="serif">good</span>.
				</h2>
				<p class="cta-lead">
					Open to internships, collaborations, and interesting
					problems. The fastest way to reach me is discord.
				</p>
				<div class="hero-actions">
					<a class="btn-primary" href={contactLinks[1].href}>
						<Icon name="discord" size={16} />
						{contactLinks[1].value}
					</a>
					<a class="btn-ghost" href="/contact">All ways to reach me</a
					>
				</div>
			</div>
		</Reveal>
	</section>
</Base>

<script>
	const syncScrollHint = () => {
		const hint = document.querySelector('.scroll-hint');
		const nearBottom =
			window.innerHeight + window.scrollY >=
			document.body.scrollHeight - 4;
		hint?.classList.toggle('is-hidden', window.scrollY > 40 || nearBottom);
	};
	window.addEventListener('scroll', syncScrollHint, { passive: true });
	document.addEventListener('astro:page-load', syncScrollHint);
	syncScrollHint();
</script>

<style>
	.section {
		padding-block: 4rem;
	}

	.hero {
		min-height: 100svh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1.25rem;
		padding-block: 5rem 4.5rem;
		position: relative;
	}
	.hero-link {
		color: inherit;
		text-decoration: underline;
		text-decoration-color: color-mix(
			in oklab,
			var(--accent) 45%,
			transparent
		);
		text-underline-offset: 5px;
		text-decoration-thickness: 1px;
		transition:
			color 0.18s ease,
			text-decoration-color 0.18s ease;
	}
	.hero-link:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.hero-name {
		font-size: clamp(2.6rem, 8vw, 5.2rem);
		line-height: 0.98;
	}
	.hero-lead {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: clamp(1.3rem, 3.2vw, 2rem);
		line-height: 1.3;
		max-width: 26ch;
		letter-spacing: -0.01em;
	}
	.hero-lead .serif {
		font-weight: 400;
	}
	.hero-sub {
		color: var(--muted);
		font-size: 0.9rem;
		letter-spacing: 0.05em;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 0.5rem;
	}
	.scroll-hint {
		position: absolute;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem;
		color: var(--muted);
		font-size: 0.66rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		transition:
			opacity 0.4s ease,
			transform 0.4s ease;
	}
	.scroll-hint.is-hidden {
		opacity: 0;
		transform: translate(-50%, 12px);
		pointer-events: none;
	}
	.scroll-hint :global(svg) {
		animation: bob 1.8s ease-in-out infinite;
	}
	@keyframes bob {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(4px);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.scroll-hint :global(svg) {
			animation: none;
		}
	}

	.about-grid {
		display: grid;
		gap: 2.5rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 900px) {
		.about-grid {
			grid-template-columns: 1.7fr 1fr;
			align-items: start;
		}
	}
	.about-body {
		display: grid;
		gap: 1.1rem;
		color: var(--muted);
		font-size: 1.05rem;
	}
	.about-body :global(strong) {
		color: var(--fg);
		font-weight: 600;
	}
	.glance {
		padding: 1.6rem;
	}
	.glance-head {
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1.1rem;
	}
	.glance dl {
		margin: 0;
		display: grid;
		gap: 1rem;
	}
	.glance dt {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin-bottom: 0.2rem;
	}
	.glance dd {
		margin: 0;
		font-size: 0.96rem;
		color: var(--fg);
		line-height: 1.5;
	}

	.project-grid {
		display: grid;
		gap: 1.25rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 720px) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	.work-more {
		margin-top: 2rem;
		display: flex;
		justify-content: center;
	}

	.skills-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(2, 1fr);
	}
	@media (min-width: 860px) {
		.skills-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.skill-card {
		padding: 1.4rem;
	}
	.skill-head {
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1rem;
	}
	.skill-card ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.5rem;
	}
	.skill-card li {
		font-size: 0.95rem;
		color: var(--fg);
	}
	.skill-link {
		color: var(--fg);
		transition: color 0.16s ease;
	}
	.skill-link:hover {
		color: var(--accent);
	}

	.rec-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.75rem;
	}
	.rec-item {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.3rem 1rem;
		align-items: baseline;
		padding: 1.1rem 1.3rem;
		border-radius: 14px;
		border: 1px solid var(--line);
		background: color-mix(in oklab, var(--surface) 45%, transparent);
		transition:
			border-color 0.18s ease,
			background-color 0.18s ease;
	}
	.rec-item:hover {
		border-color: color-mix(in oklab, var(--accent) 40%, var(--line));
		background: color-mix(in oklab, var(--surface) 70%, transparent);
	}
	.rec-main {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.6rem;
	}
	.rec-title {
		font-family: var(--font-sans);
		font-weight: 600;
		font-size: 1.05rem;
	}
	.rec-org {
		color: var(--accent);
		font-size: 0.9rem;
	}
	.rec-note {
		grid-column: 1 / -1;
		color: var(--muted);
		font-size: 0.9rem;
		max-width: 60ch;
	}
	.rec-period {
		font-size: 0.74rem;
		color: var(--muted);
		white-space: nowrap;
	}

	.contact-cta {
		padding: clamp(2rem, 5vw, 3.5rem);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}
	.cta-title {
		font-size: clamp(1.8rem, 4.5vw, 2.8rem);
	}
	.cta-lead {
		color: var(--muted);
		max-width: 44ch;
	}
	.contact-cta .hero-actions {
		justify-content: center;
	}
</style>
